# ============================================
# LinkHub — Git Ignore
# ============================================

# ── Dependencies ──────────────────────────────
node_modules/
Frontend/node_modules/

# ── Python ────────────────────────────────────
Backend/venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ── Environment ───────────────────────────────
# .env
# .env.local
# .env.*.local
Backend/.env

# ── Next.js ───────────────────────────────────
Frontend/.next/
Frontend/out/
Frontend/.next/cache/

# ── IDE ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Vercel ────────────────────────────────────
.vercel/

# ── Testing ───────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Misc ──────────────────────────────────────
*.log
*.pid
Backend/env_upload
Frontend/env_upload
